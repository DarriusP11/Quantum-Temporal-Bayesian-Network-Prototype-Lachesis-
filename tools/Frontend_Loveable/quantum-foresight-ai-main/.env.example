# Supabase — get from https://supabase.com/dashboard/project/<your-project>/settings/api
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJ...your-anon-key...

# Backend API URL (localhost for dev, Railway URL for production)
VITE_API_URL=http://localhost:8000

# Stripe — get from https://dashboard.stripe.com/apikeys (Publishable key)
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Stripe Price IDs — get from https://dashboard.stripe.com/products
VITE_STRIPE_PRO_MONTHLY_PRICE_ID=price_...
VITE_STRIPE_PRO_ANNUAL_PRICE_ID=price_...
VITE_STRIPE_ENTERPRISE_MONTHLY_PRICE_ID=price_...
VITE_STRIPE_ENTERPRISE_ANNUAL_PRICE_ID=price_...
